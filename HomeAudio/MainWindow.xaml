<Window x:Class="HomeAudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:HomeAudio.ViewModels"
        xmlns:conv="clr-namespace:HomeAudio.Converters"
        mc:Ignorable="d"
        Title="HomeAudio — Multi-Device Player"
        Width="1100" Height="740"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BrushBackgroundDark}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
        <conv:InverseBoolConverter             x:Key="InvBool"/>
        <conv:BoolToActiveBrushConverter       x:Key="ActiveBrush"
            ActiveBrush="{StaticResource BrushDeviceActive}"
            InactiveBrush="{StaticResource BrushDeviceInactive}"/>
        <conv:VolumeToPercentConverter    x:Key="VolPct"/>
        <conv:LatencyToStringConverter    x:Key="LatencyStr"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ═══ TITLE BAR ═══ -->
        <Border Grid.Row="0" Background="{StaticResource BrushBackgroundMid}">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎵" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="HomeAudio" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource BrushAccentCyan}" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Multi-Device Player" FontSize="14"
                               Foreground="{StaticResource BrushTextSecondary}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenBluetoothCommand}"
                            ToolTip="Open Windows Bluetooth settings" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔵" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Bluetooth" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding OpenSoundSettingsCommand}"
                            ToolTip="Open Windows Sound settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔊" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Sound" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1" Margin="12,12,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: WaveOut devices ─── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushBackgroundMid}"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BrushBackgroundPanel}"
                            CornerRadius="8,8,0,0" Padding="12,10">
                        <Grid>
                            <TextBlock Text="BLUETOOTH / USB DEVICES"
                                       Style="{StaticResource SectionHeader}"
                                       VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}"
                                    Command="{Binding RefreshDevicesCommand}"
                                    ToolTip="Refresh WaveOut device list">
                                <TextBlock Text="↻" FontSize="18"/>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                        <ItemsControl ItemsSource="{Binding Devices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:AudioDeviceViewModel}">
                                    <Border Margin="0,3" CornerRadius="6" Padding="10,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#22444466"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="#1A2EC4B6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                      VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           FontWeight="Medium"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding DeviceIcon}" FontSize="11" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Bluetooth" FontSize="11"
                                                               Foreground="{StaticResource BrushAccentCyan}"
                                                               Visibility="{Binding IsBluetoothDevice, Converter={StaticResource BoolVis}}"/>
                                                    <TextBlock Text="Built-in / USB" FontSize="11"
                                                               Foreground="{StaticResource BrushTextSecondary}"
                                                               Visibility="{Binding IsBluetoothDevice, Converter={StaticResource InvBoolVis}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Column="2" CornerRadius="4"
                                                    Background="{StaticResource BrushStereoPair}"
                                                    Padding="6,2" VerticalAlignment="Center"
                                                    Visibility="{Binding IsStereoPairMember, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding StereoPairRole}"
                                                           FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" Text="✓ Check to include in playback"
                               FontSize="11" Foreground="{StaticResource BrushTextSecondary}"
                               Margin="12,8" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ─── MIDDLE: Sonos devices ─── -->
            <Border Grid.Column="2"
                    Background="{StaticResource BrushBackgroundMid}"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Sonos header -->
                    <Border Grid.Row="0" Background="{StaticResource BrushBackgroundPanel}"
                            CornerRadius="8,8,0,0" Padding="12,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="📡" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="SONOS SPEAKERS"
                                           Style="{StaticResource SectionHeader}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}"
                                    Command="{Binding DiscoverSonosDevicesCommand}"
                                    IsEnabled="{Binding IsSonosDiscovering, Converter={StaticResource InvBoolVis}}"
                                    ToolTip="Scan network for Sonos speakers">
                                <TextBlock Text="🔍" FontSize="15"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Discovering indicator -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="{Binding IsSonosDiscovering, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="🔍" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Scanning network…"
                                   FontSize="13" Foreground="{StaticResource BrushTextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Sonos device list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8"
                                  Visibility="{Binding IsSonosDiscovering, Converter={StaticResource InvBoolVis}}">
                        <StackPanel>
                            <!-- Empty state -->
                            <TextBlock Text="{Binding SonosStatus}"
                                       FontSize="12"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="4,8,4,12"
                                       Visibility="{Binding SonosDevices.Count,
                                           Converter={StaticResource InvBoolVis}}"/>

                            <ItemsControl ItemsSource="{Binding SonosDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:SonosDeviceViewModel}">
                                        <Border Margin="0,3" CornerRadius="6" Padding="10,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#22444466"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#1A2EC4B6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsActive, Mode=TwoWay}"
                                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                                               FontWeight="Medium"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="📡" FontSize="11" Margin="0,0,4,0"/>
                                                        <TextBlock Text="{Binding ModelName}" FontSize="11"
                                                                   Foreground="{StaticResource BrushAccentGreen}"/>
                                                        <TextBlock Text=" · " FontSize="11"
                                                                   Foreground="{StaticResource BrushTextSecondary}"/>
                                                        <TextBlock Text="{Binding IpAddress}" FontSize="11"
                                                                   Foreground="{StaticResource BrushTextSecondary}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Grid.Column="2" CornerRadius="4"
                                                        Background="{StaticResource BrushStereoPair}"
                                                        Padding="6,2" VerticalAlignment="Center"
                                                        Visibility="{Binding IsStereoPairMember, Converter={StaticResource BoolVis}}">
                                                    <TextBlock Text="{Binding StereoPairRole}"
                                                               FontSize="11" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding DiscoverSonosDevicesCommand}"
                            IsEnabled="{Binding IsSonosDiscovering, Converter={StaticResource InvBoolVis}}"
                            Margin="12,8" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="13" Margin="0,0,6,0"/>
                            <TextBlock Text="Discover Sonos Speakers"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ─── RIGHT: Settings + Stereo pairs ─── -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- File -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>   <!-- Mic input -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>      <!-- Pair + settings -->
                </Grid.RowDefinitions>

                <!-- File Open -->
                <Border Grid.Row="0"
                        Background="{StaticResource BrushBackgroundMid}"
                        CornerRadius="8" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="AUDIO FILE" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="{Binding LoadedFileName}" FontSize="14"
                                       FontWeight="Medium" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding LoadedFilePath}"/>
                            <TextBlock Text="{Binding DurationDisplay, StringFormat='Duration: {0}'}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                                Command="{Binding OpenFileCommand}" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Open File"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Mic Input -->
                <Border Grid.Row="2"
                        Background="{StaticResource BrushBackgroundMid}"
                        CornerRadius="8" Padding="16,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header row -->
                        <Grid Grid.Row="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🎤" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="MIC PASSTHROUGH"
                                           Style="{StaticResource SectionHeader}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}"
                                    Command="{Binding RefreshInputDevicesCommand}"
                                    ToolTip="Refresh microphone list">
                                <TextBlock Text="↻" FontSize="18"/>
                            </Button>
                        </Grid>

                        <!-- Mic selector + start/stop -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding InputDevices}"
                                      SelectedItem="{Binding SelectedInputDevice, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      VerticalAlignment="Center"
                                      IsEnabled="{Binding IsMicActive, Converter={StaticResource InvBool}}"/>

                            <!-- Start button (visible when inactive) -->
                            <Button Grid.Column="2"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding StartMicCommand}"
                                    Visibility="{Binding IsMicActive, Converter={StaticResource InvBoolVis}}"
                                    ToolTip="Start mic passthrough to selected output devices">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎤" FontSize="13" Margin="0,0,5,0"/>
                                    <TextBlock Text="Start"/>
                                </StackPanel>
                            </Button>

                            <!-- Stop button (visible when active) -->
                            <Button Grid.Column="2"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding StopMicCommand}"
                                    Visibility="{Binding IsMicActive, Converter={StaticResource BoolVis}}"
                                    ToolTip="Stop mic passthrough">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏹" FontSize="13" Margin="0,0,5,0"/>
                                    <TextBlock Text="Stop Mic"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Stereo pairs + Device settings -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <!-- Device settings (active WaveOut + Sonos) -->
                    <Border Grid.Column="0"
                            Background="{StaticResource BrushBackgroundMid}"
                            CornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource BrushBackgroundPanel}"
                                    CornerRadius="8,8,0,0" Padding="12,10">
                                <TextBlock Text="DEVICE SETTINGS" Style="{StaticResource SectionHeader}"/>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12">
                                <StackPanel>
                                    <!-- WaveOut device settings -->
                                    <ItemsControl ItemsSource="{Binding Devices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:AudioDeviceViewModel}">
                                                <Border Margin="0,0,0,12"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolVis}}">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                            <TextBlock Text="{Binding DeviceIcon}" FontSize="12" Margin="0,0,5,0"/>
                                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <Grid Margin="0,0,0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="55"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="42"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Volume" FontSize="11"
                                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                                       VerticalAlignment="Center"/>
                                                            <Slider Grid.Column="1" Style="{StaticResource VolumeSlider}"
                                                                    Minimum="0" Maximum="1"
                                                                    Value="{Binding Volume, Mode=TwoWay}"
                                                                    VerticalAlignment="Center" Margin="6,0"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding Volume, Converter={StaticResource VolPct}}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource BrushAccentCyan}"
                                                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <Grid Margin="0,0,0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="55"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="50"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Delay" FontSize="11"
                                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                                       VerticalAlignment="Center"/>
                                                            <Slider Grid.Column="1" Style="{StaticResource LatencySlider}"
                                                                    Minimum="-500" Maximum="500"
                                                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                                                    Value="{Binding LatencyOffsetMs, Mode=TwoWay}"
                                                                    VerticalAlignment="Center" Margin="6,0"
                                                                    ToolTip="Sync offset (ms). Positive = play later"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding LatencyOffsetMs, Converter={StaticResource LatencyStr}}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource BrushAccentGreen}"
                                                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <Separator Background="#22FFFFFF" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Sonos device settings -->
                                    <ItemsControl ItemsSource="{Binding SonosDevices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:SonosDeviceViewModel}">
                                                <Border Margin="0,0,0,12"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolVis}}">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                            <TextBlock Text="📡" FontSize="12" Margin="0,0,5,0"/>
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <Grid Margin="0,0,0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="55"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="42"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Volume" FontSize="11"
                                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                                       VerticalAlignment="Center"/>
                                                            <Slider Grid.Column="1" Style="{StaticResource VolumeSlider}"
                                                                    Minimum="0" Maximum="1"
                                                                    Value="{Binding Volume, Mode=TwoWay}"
                                                                    VerticalAlignment="Center" Margin="6,0"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding Volume, Converter={StaticResource VolPct}}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource BrushAccentCyan}"
                                                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <Grid Margin="0,0,0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="55"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="50"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Delay" FontSize="11"
                                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                                       VerticalAlignment="Center"/>
                                                            <Slider Grid.Column="1" Style="{StaticResource LatencySlider}"
                                                                    Minimum="0" Maximum="5000"
                                                                    TickFrequency="100" IsSnapToTickEnabled="True"
                                                                    Value="{Binding LatencyOffsetMs, Mode=TwoWay}"
                                                                    VerticalAlignment="Center" Margin="6,0"
                                                                    ToolTip="Sonos buffer delay (ms). Start at ~2000 ms and tune to sync."/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding LatencyOffsetMs, Converter={StaticResource LatencyStr}}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource BrushAccentGreen}"
                                                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <Separator Background="#22FFFFFF" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Stereo pair panels (stacked) -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- BT / USB stereo pair -->
                        <Border Grid.Row="0"
                                Background="{StaticResource BrushBackgroundMid}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource BrushBackgroundPanel}"
                                        CornerRadius="8,8,0,0" Padding="10,8">
                                    <Grid>
                                        <TextBlock Text="BT STEREO PAIR"
                                                   Style="{StaticResource SectionHeader}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox HorizontalAlignment="Right"
                                                  IsChecked="{Binding StereoPairEnabled, Mode=TwoWay}"
                                                  Content="On" FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="12,8"
                                            IsEnabled="{Binding StereoPairEnabled}">
                                    <TextBlock Text="◀  LEFT" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushAccentCyan}" Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding AvailableDevicesForPair}"
                                              SelectedItem="{Binding StereoPairLeft, Mode=TwoWay}"
                                              DisplayMemberPath="Name" Margin="0,0,0,8"/>
                                    <TextBlock Text="RIGHT  ▶" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushStereoPair}" Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding AvailableDevicesForPair}"
                                              SelectedItem="{Binding StereoPairRight, Mode=TwoWay}"
                                              DisplayMemberPath="Name" Margin="0,0,0,8"/>
                                    <Border CornerRadius="5" Padding="8,5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A2EC4B6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StereoPairValid}" Value="False">
                                                        <Setter Property="Background" Value="#1AFF6B6B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="⚠ Select two different devices"/>
                                                    <Setter Property="Foreground" Value="{StaticResource BrushStereoPair}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StereoPairValid}" Value="True">
                                                            <Setter Property="Text" Value="✓ Ready"/>
                                                            <Setter Property="Foreground" Value="{StaticResource BrushAccentGreen}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Sonos stereo pair -->
                        <Border Grid.Row="2"
                                Background="{StaticResource BrushBackgroundMid}"
                                CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource BrushBackgroundPanel}"
                                        CornerRadius="8,8,0,0" Padding="10,8">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="📡" FontSize="12" Margin="0,0,5,0"/>
                                            <TextBlock Text="SONOS STEREO PAIR"
                                                       Style="{StaticResource SectionHeader}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <CheckBox HorizontalAlignment="Right"
                                                  IsChecked="{Binding SonosStereoPairEnabled, Mode=TwoWay}"
                                                  Content="On" FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Row="1" Margin="12,8"
                                            IsEnabled="{Binding SonosStereoPairEnabled}">
                                    <TextBlock Text="◀  LEFT" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushAccentCyan}" Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding AvailableSonosForPair}"
                                              SelectedItem="{Binding SonosStereoPairLeft, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayName" Margin="0,0,0,8"/>
                                    <TextBlock Text="RIGHT  ▶" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource BrushStereoPair}" Margin="0,0,0,3"/>
                                    <ComboBox ItemsSource="{Binding AvailableSonosForPair}"
                                              SelectedItem="{Binding SonosStereoPairRight, Mode=TwoWay}"
                                              DisplayMemberPath="DisplayName" Margin="0,0,0,8"/>
                                    <TextBlock Text="Tip: each speaker plays one channel (L or R). Tune Delay to sync."
                                               FontSize="10"
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               TextWrapping="Wrap"/>
                                    <Border CornerRadius="5" Padding="8,5" Margin="0,6,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A2EC4B6"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SonosStereoPairValid}" Value="False">
                                                        <Setter Property="Background" Value="#1AFF6B6B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="⚠ Select two different speakers"/>
                                                    <Setter Property="Foreground" Value="{StaticResource BrushStereoPair}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SonosStereoPairValid}" Value="True">
                                                            <Setter Property="Text" Value="✓ Stereo pair ready"/>
                                                            <Setter Property="Foreground" Value="{StaticResource BrushAccentGreen}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══ TRANSPORT ═══ -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushBackgroundMid}"
                Margin="12,12,12,0" CornerRadius="8" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Seek bar -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding PositionDisplay}"
                               FontSize="13" FontFamily="Consolas"
                               Foreground="{StaticResource BrushAccentCyan}"
                               VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" x:Name="SeekSlider"
                            Style="{StaticResource SeekSlider}"
                            Minimum="0" Maximum="{Binding DurationSeconds}"
                            Value="{Binding PositionSeconds, Mode=TwoWay}"
                            VerticalAlignment="Center" Margin="8,0"
                            IsMoveToPointEnabled="True"
                            PreviewMouseDown="SeekSlider_PreviewMouseDown"
                            PreviewMouseUp="SeekSlider_PreviewMouseUp"/>
                    <TextBlock Grid.Column="2" Text="{Binding DurationDisplay}"
                               FontSize="13" FontFamily="Consolas"
                               Foreground="{StaticResource BrushTextSecondary}"
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Transport buttons -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding LoadedFileName}"
                               FontSize="14" FontWeight="Medium"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" MaxWidth="280"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource TransportButton}"
                                Command="{Binding StopCommand}"
                                ToolTip="Stop" Margin="0,0,8,0">
                            <TextBlock Text="⏹" FontSize="16"/>
                        </Button>
                        <Button Style="{StaticResource TransportButton}"
                                Width="54" Height="54"
                                Command="{Binding PlayCommand}"
                                ToolTip="Play" Margin="0,0,8,0">
                            <TextBlock Text="▶" FontSize="20"/>
                        </Button>
                        <Button Style="{StaticResource TransportButton}"
                                Command="{Binding PauseCommand}"
                                ToolTip="Pause">
                            <TextBlock Text="⏸" FontSize="16"/>
                        </Button>
                    </StackPanel>

                    <!-- Active devices summary -->
                    <WrapPanel Grid.Column="2" HorizontalAlignment="Right"
                               VerticalAlignment="Center" Orientation="Horizontal">
                        <ItemsControl ItemsSource="{Binding Devices}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:AudioDeviceViewModel}">
                                    <Border Margin="3,2" CornerRadius="4" Padding="6,3"
                                            Background="#1A2EC4B6"
                                            Visibility="{Binding IsActive, Converter={StaticResource BoolVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DeviceIcon}" FontSize="11" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="11"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="100"
                                                       Foreground="{StaticResource BrushAccentCyan}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding SonosDevices}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SonosDeviceViewModel}">
                                    <Border Margin="3,2" CornerRadius="4" Padding="6,3"
                                            Background="#1A2EC4B6"
                                            Visibility="{Binding IsActive, Converter={StaticResource BoolVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📡" FontSize="11" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="11"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="100"
                                                       Foreground="{StaticResource BrushAccentGreen}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Background="{StaticResource BrushBackgroundPanel}" Padding="12,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="{StaticResource BrushTextSecondary}"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
